---
import Layout from '@/layouts/Layout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { ThemeToggle } from '@/components/ThemeToggle';
---

<Layout title="How to Run BIP-110 | Installation Guide" description="Step-by-step guide to installing and running a BIP-110 enabled Bitcoin node">
  <main class="min-h-screen">
    <div class="absolute top-6 right-6 z-20">
      <ThemeToggle client:load />
    </div>

    <section class="py-24 px-6">
      <div class="max-w-4xl mx-auto">
        <a href="/" class="inline-flex items-center gap-2 text-muted-foreground hover:text-primary transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to BIP-110
        </a>

        <h1 class="text-4xl font-bold mb-4">How to Run BIP-110</h1>
        <p class="text-xl text-muted-foreground mb-12">
          Support BIP-110 by running a node that signals for activation. Choose your preferred installation method below.
        </p>

        <div class="space-y-8">
          <Card>
            <CardHeader>
              <CardTitle>Bitcoin Knots (Direct Download)</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p class="text-muted-foreground">
                Download the BIP-110 enabled Bitcoin Knots release directly from GitHub.
              </p>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Installation steps:</p>
                <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                  <li>Download the release for your platform from the GitHub releases page</li>
                  <li>Verify the download signatures (recommended)</li>
                  <li>Replace your existing Bitcoin Core/Knots installation</li>
                  <li>Start your node - it will automatically begin signaling for BIP-110</li>
                </ol>
              </div>
              <a
                href="https://github.com/dathonohm/bitcoin/releases/tag/v29.2.knots20251110%2Bbip110-v0.1"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                Download from GitHub
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </CardContent>
          </Card>

          <div id="start9">
          <Card>
            <CardHeader>
              <CardTitle>Start9</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p class="text-muted-foreground">
                Install from the BIP-110 registry or download the package directly for your StartOS version.
              </p>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Option A: Install from Registry (StartOS 0.3.5.1)</p>
                <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                  <li>Go to System and click 5 times on "Manage" to unlock dev tools</li>
                  <li>Go to Marketplace → Change → Add Custom Registry</li>
                  <li>Paste <code class="bg-background rounded px-1">https://start9.bip110.dev</code> and click "Save and Connect"</li>
                  <li>Click on Bitcoin → "Bitcoin Knots (BIP-110 UASF)" → Reinstall</li>
                </ol>
              </div>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Option B: Sideload</p>
                <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                  <li>Download the .s9pk file for your StartOS version</li>
                  <li>In your Start9 UI, go to System → Sideload</li>
                  <li>Upload the .s9pk file</li>
                </ol>
              </div>
              <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3">
                <a
                  href="https://start9.bip110.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors w-full sm:w-auto"
                >
                  Install from Store
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
                <a
                  href="https://github.com/dathonohm/knots-startos/releases/tag/v29.2.knots20251110%2Bbip110-v0.1rc3"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors w-full sm:w-auto"
                >
                  Download for StartOS 0.3.5.1
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
                <a
                  href="https://github.com/dathonohm/knots-startos/releases/tag/v29.2.knots20251110%2Bbip110-v0.1rc3-startos0.4.0"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors w-full sm:w-auto"
                >
                  Download for StartOS 0.4
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </CardContent>
          </Card>
          </div>

          <div id="umbrel">
          <Card>
            <CardHeader>
              <CardTitle>Umbrel</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p class="text-muted-foreground">
                One-click install from the Umbrel community app store.
              </p>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Installation steps:</p>
                <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                  <li>Open your Umbrel dashboard</li>
                  <li>Update the Bitcoin Knots app if prompted in the App Store</li>
                  <li>Open the Bitcoin Knots app</li>
                  <li>Go to settings &gt; Bitcoin Knots version &gt; Select BIP110</li>
                  <li>Save settings</li>
                </ol>
              </div>
              <a
                href="https://github.com/getumbrel/umbrel-apps/pull/4237"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                View on GitHub
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </CardContent>
          </Card>
          </div>

          <div id="mynode">
          <Card>
            <CardHeader>
              <CardTitle>myNode</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p class="text-muted-foreground">
                Available in the Custom Bitcoin Versions settings.
              </p>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Installation steps:</p>
                <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                  <li>Update your myNode to the latest version</li>
                  <li>Go to Settings and find the Custom Bitcoin Versions list</li>
                  <li>Select the BIP-110 option</li>
                  <li>Save settings and restart</li>
                </ol>
              </div>
              <a
                href="https://github.com/mynodebtc/mynode/pull/986"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                View on GitHub
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </CardContent>
          </Card>
          </div>

          <div id="parmanode">
          <Card>
            <CardHeader>
              <CardTitle>Parmanode</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p class="text-muted-foreground">
                Simple one-click style install for Parmanode users.
              </p>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Installation steps:</p>
                <ol class="list-decimal list-inside space-y-2 text-sm text-muted-foreground">
                  <li>Make sure you have the latest Parmanode version</li>
                  <li>Install Bitcoin using Parmanode</li>
                  <li>Select BIP-110 when the option appears during installation</li>
                </ol>
              </div>
              <a
                href="https://www.youtube.com/watch?v=JpvNDL9Opns"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                Watch Tutorial
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </CardContent>
          </Card>
          </div>

          <div id="docker">
          <Card>
            <CardHeader>
              <CardTitle>Docker</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p class="text-muted-foreground">
                For advanced users running their own Docker infrastructure. Uses the same GUIX-built binaries as Umbrel.
              </p>
              <div class="bg-muted/50 rounded-lg p-4 space-y-3">
                <p class="font-medium">Docker image:</p>
                <code class="block bg-background rounded px-3 py-2 text-sm font-mono break-all">
                  ghcr.io/retropex/bitcoin:29.2.knots20251110-bip110-RC3
                </code>
              </div>
              <a
                href="https://github.com/Retropex/docker-bitcoind-prebuilt/pkgs/container/bitcoin/647778380?tag=29.2.knots20251110-bip110-RC3"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                View on GHCR
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </CardContent>
          </Card>
          </div>
        </div>

        <div class="mt-16 pt-8 border-t border-border">
          <h2 class="text-2xl font-bold mb-4">Need Help?</h2>
          <p class="text-muted-foreground mb-4">
            If you encounter any issues or have questions about running BIP-110, you can:
          </p>
          <ul class="list-disc list-inside space-y-2 text-muted-foreground">
            <li>Open an issue on the <a href="https://github.com/dathonohm/bitcoin/issues" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GitHub repository</a></li>
            <li>Read the full <a href="https://github.com/dathonohm/bips/blob/reduced-data/bip-0110.mediawiki" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">BIP-110 specification</a></li>
          </ul>
        </div>
      </div>
    </section>
  </main>
</Layout>
