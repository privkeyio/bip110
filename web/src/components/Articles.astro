---
import { Card, CardContent } from '@/components/ui/card';
import { articles } from '@/lib/content';
---

<section id="articles" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4">Articles</h2>
    <p class="text-muted-foreground text-center mb-12 max-w-2xl mx-auto">
      In-depth reading on BIP-110 and why it matters
    </p>

    <div class="grid gap-6">
      {articles.map((article) => (
        <a
          href={article.link}
          target="_blank"
          rel="noopener noreferrer"
          class="block group"
        >
          <Card className="border-border/50 bg-card/50 backdrop-blur transition-colors group-hover:border-primary/30">
            <CardContent className="pt-6">
              <h3 class="font-semibold text-lg mb-2 group-hover:text-primary transition-colors">
                {article.title}
                <svg aria-hidden="true" class="w-4 h-4 inline-block ml-2 text-muted-foreground group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </h3>
              <p class="text-sm text-muted-foreground mb-3">{article.description}</p>
              <div class="flex gap-4 text-xs text-muted-foreground/70">
                <span>{article.author}</span>
                <span aria-hidden="true">•</span>
                <span>{article.date}</span>
              </div>
            </CardContent>
          </Card>
        </a>
      ))}
    </div>
  </div>
</section>
